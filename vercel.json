{
  "version": 2,
  "builds": [
    {
      "src": "**/*.{html,jpg,jpeg,png,gif,svg,ico,webp,js,css,json,woff2}",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/about$",
      "dest": "/about/index.html"
    },
    {
      "src": "^/services$",
      "dest": "/services/index.html"
    },
    {
      "src": "^/contact$",
      "dest": "/contact/index.html"
    },
    {
      "src": "^/admin$",
      "dest": "/admin/index.html"
    },
    {
      "src": "^/api/submit$",
      "dest": "/api/submit.js"
    },
    {
      "src": "^/api/leads$",
      "dest": "/api/leads.js"
    },
    {
      "src": "^/(.*\\..*)$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}
